{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Hangfire": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "FamilyAccountApi",
    "Audience": "FamilyAccountClients",
    "TokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },
  "Smtp": {
    "Port": 587,
    "EnableSsl": true,
    "FromName": "Family Account"
  },
  "Hangfire": {
    "DashboardPath": "/hangfire",
    "WorkerCount": 5,
    "Queues": ["critical", "default", "integration", "low"],
    "AutomaticRetryAttempts": 3
  },
  "App": {
    "NameCustomer": "Family Account",
    "SloganCustomer": "Control de finanzas familiares",
    "Version": "1.0.0"
  }
}
